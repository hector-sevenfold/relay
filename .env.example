PORT=8788
ADMIN_PASSWORD=change-me

# Optional local overrides. If omitted, the app stores SQLite in:
# - DATABASE_PATH, if set
# - DATA_DIR/rss-feed-generator.db, if set
# - RAILWAY_VOLUME_MOUNT_PATH/rss-feed-generator.db on Railway, if present
# - ./data/rss-feed-generator.db otherwise
# DATABASE_PATH=/absolute/path/to/rss-feed-generator.db
# DATA_DIR=./data

# Railway notes:
# - Set ADMIN_PASSWORD in Railway production
# - Do not set PORT on Railway unless you have a specific reason
# - Attach a persistent volume and mount it at /app/data
# - Usually you do not need to set DATABASE_PATH or DATA_DIR on Railway when using /app/data
